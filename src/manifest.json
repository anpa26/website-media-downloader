{
  "name": "Website Media Downloader",
  "manifest_version": 3,
  "version": "1.5.9",
  "description": "A powerful tool to download videos, music, and live streams from any website. Usage: 1. Play media on a website, 2. Click the extension icon to detect links, 3. Choose quality and click Download. Supports HLS/M3U8, MPD, and offline conversion.",
  "browser_specific_settings": {
    "gecko": {
      "id": "{924f7c81-8b1e-4b6e-9e7c-8e4a9e1d2c3f}",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    }
  },
  "permissions": [
    "storage",
    "unlimitedStorage",
    "downloads",
    "notifications",
    "activeTab",
    "webRequest",
    "webRequestBlocking",
    "webRequestFilterResponse",
    "scripting"
  ],
  "optional_permissions": [
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "homepage_url": "https://github.com/anpa26/website-media-downloader",
  "background": {
    "service_worker": "background.js",
    "scripts": [
      "background.js"
    ]
  },
  "icons": {
    "96": "icons/file_save.svg",
    "128": "icons/file_save.svg"
  },
  "action": {
    "default_title": "__MSG_actionTitle__"
  },
  "default_locale": "en",
  "options_page": "popup.html?options=true"
}