{
  "name": "Website Media Downloader",
  "manifest_version": 3,
  "version": "1.5.0",
  "description": "__MSG_extensionDescription__",
  "author": "helloyanis, improved by anpa26",
  "developer": {
    "name": "helloyanis, improved by anpa26",
    "url": "https://github.com/anpa26/website-media-downloader"
  },
  "permissions": [
    "storage",
    "webRequest",
    "webRequestBlocking",
    "webRequestFilterResponse",
    "unlimitedStorage"
  ],
  "optional_permissions": [
    "downloads"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "homepage_url": "https://github.com/anpa26/website-media-downloader",
  "background": {
    "service_worker": "background.js",
    "scripts": [
      "background.js"
    ]
  },
  "icons": {
    "96": "icons/file_save.svg",
    "128": "icons/file_save.svg"
  },
  "action": {
    "default_title": "__MSG_actionTitle__"
  },
  "default_locale": "en",
  "options_page": "popup.html?options=true"
}